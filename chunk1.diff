+
+    Methods:
+        model_dump() -> dict: return all instance attributes as a dict
+        __repr__() -> str: "ClassName(field=value, ...)"
+
+    AI use: understanding Pydantic's BaseModel pattern (Week 1).
+    """
+    def __init__(self, **fields):
