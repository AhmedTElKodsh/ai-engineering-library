# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_engineering_curriculum?schema=public"

# JWT Secret - CRITICAL: Change this to a strong random string in production
# Generate using: openssl rand -base64 32
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_MINIMUM_32_CHARACTERS_REQUIRED"

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="ai-eng-curriculum-content"

# ElasticSearch
ELASTICSEARCH_URL="http://localhost:9200"

# OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Server
PORT=3000
NODE_ENV="development"

# Frontend URL
FRONTEND_URL="http://localhost:3000"